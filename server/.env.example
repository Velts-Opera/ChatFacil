# ── Rede ────────────────────────────────────────────────────────────────────
PORT=3001
BRIDGE_HOST=0.0.0.0

# ── Segurança ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
BRIDGE_SECRET=INSIRA_UM_SEGREDO_FORTE_AQUI

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=INSIRA_A_SERVICE_ROLE_KEY_AQUI

# ── IA (opcional) ────────────────────────────────────────────────────────────
GEMINI_API_KEY=INSIRA_SUA_GEMINI_API_KEY_AQUI
GEMINI_MODEL=gemini-1.5-flash

# ── Sessões ───────────────────────────────────────────────────────────────────
SESSION_DATA_PATH=/data
QR_EVENT_MODE=webhook

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=https://SEU_PROJETO.supabase.co
