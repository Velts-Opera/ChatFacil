PORT=3001
# Desenvolvimento local: 127.0.0.1 (sem exigir BRIDGE_SECRET).
# Produção hospedada (Railway/Render/VPS): 0.0.0.0 — BRIDGE_SECRET vira obrigatório.
BRIDGE_HOST=127.0.0.1

# Produção: origens permitidas para CORS, separadas por vírgula
# (normalmente vazio, porque quem chama o bridge é a Edge Function, não o navegador)
# CORS_ORIGINS=https://seu-app.vercel.app

# URL do seu projeto Supabase (ex: https://ncosftsthrzznevzkvbi.supabase.co)
SUPABASE_URL=https://ncosftsthrzznevzkvbi.supabase.co

# Roteamento direto do servidor-mãe (não use a chave anon aqui)
QR_EVENT_MODE=direct
SUPABASE_SERVICE_ROLE_KEY=cole_a_service_role_key_apenas_no_servidor
GEMINI_API_KEY=cole_sua_chave_central_do_gemini
GEMINI_MODEL=gemini-1.5-flash

# Segredo compartilhado entre bridge e edge function (gere um aleatório).
# Obrigatório se BRIDGE_HOST não for um endereço local.
BRIDGE_SECRET=troque_por_um_segredo_aleatorio_forte

# Pasta onde as sessões serão salvas
SESSIONS_DIR=./sessions
