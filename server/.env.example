# ── Rede ────────────────────────────────────────────────────────────────────
PORT=3001
# Desenvolvimento local: 127.0.0.1 (sem exigir BRIDGE_SECRET).
# Produção hospedada (Railway/Render/VPS): 0.0.0.0 — BRIDGE_SECRET vira obrigatório.
BRIDGE_HOST=0.0.0.0

# ── Segurança ────────────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32 (use o MESMO valor nos secrets do Supabase)
BRIDGE_SECRET=INSIRA_UM_SEGREDO_FORTE_AQUI

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://SEU_PROJETO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=INSIRA_A_SERVICE_ROLE_KEY_AQUI

# ── IA (opcional) ────────────────────────────────────────────────────────────
GEMINI_API_KEY=INSIRA_SUA_GEMINI_API_KEY_AQUI
GEMINI_MODEL=gemini-1.5-flash

# ── Sessões ───────────────────────────────────────────────────────────────────
# Monte um volume persistente nesse caminho (Railway: Volume em /data)
SESSION_DATA_PATH=/data
# 'webhook' envia eventos para a Edge Function whatsapp-qr-event;
# 'direct' processa IA e persistência direto no bridge.
QR_EVENT_MODE=webhook

# ── CORS (só importa no modo dev com navegador falando direto com o bridge) ───
# Aceita ALLOWED_ORIGINS ou CORS_ORIGINS, separadas por vírgula.
# ALLOWED_ORIGINS=http://localhost:5173
